{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "pair.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.js"
    },
    {
      "src": "/pair",
      "dest": "/pair.js"
    },
    {
      "src": "/code",
      "dest": "/pair.js"
    },
    {
      "src": "/health",
      "dest": "/index.js"
    }
  ]
}
