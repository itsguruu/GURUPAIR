{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    },
    {
      "src": "pair.js",
      "use": "@vercel/node"
    },
    {
      "src": "qr.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.js"
    },
    {
      "src": "/pair",
      "dest": "/pair.js"
    },
    {
      "src": "/qrpage",
      "dest": "/qr.js"
    },
    {
      "src": "/code",
      "dest": "/pair.js"
    }
  ],
  "functions": {
    "index.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "pair.js": {
      "maxDuration": 60,
      "memory": 1024
    },
    "qr.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  }
}
